# Copy this file to .env and fill in your keys.
#   cp .env.example .env

# Required: your Anthropic key powers the agent (Claude Opus).
ANTHROPIC_API_KEY=sk-ant-...

# Required: your OpenAI key powers the embedding model (text-embedding-3-small).
OPENAI_API_KEY=sk-...

# ---- Everything below has sensible defaults; you usually don't need to touch it ----

# The agent model (any Anthropic model id).
AGENT_MODEL=anthropic:claude-opus-4-1

# Embedding model + dimension. If you change the model, update EMBEDDING_DIM to match.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Toggle the HyDE search strategy (true/false). When false, the agent's
# hyde_search tool is removed and /search?method=hyde returns a 400.
HYDE_ENABLED=true

# Chunking knobs for the PDF ingest pipeline (characters).
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# Postgres connection. The docker-compose service is named 'db'.
DATABASE_URL=postgresql://search:search@db:5432/search
# ---- Evaluation harness (evaluator/) ----

# Opik tracing. `docker compose` defaults this to the local Opik instance
# (start it with `make opik`). Leave unset / stop Opik to disable tracing.
# OPIK_URL_OVERRIDE=http://host.docker.internal:5173/api
OPIK_PROJECT_NAME=search-agent

# The LLM the evaluator's judges use.
JUDGE_MODEL=claude-sonnet-4-6

# ViDoRe v3 subset to benchmark against.
VIDORE_DATASET=vidore/vidore_v3_industrial
MAX_DOCUMENTS=10
MAX_QUESTIONS=15
